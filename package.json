{
  "name": "codealpha-project-management",
  "version": "1.0.0",
  "description": "Collaborative Project Management Tool (Trello/Asana style) with real-time Kanban boards over WebSockets.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "seed": "node seed.js",
    "setup": "prisma migrate dev --name init && node seed.js",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "framer-motion": "^12.42.0",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0"
  }
}
