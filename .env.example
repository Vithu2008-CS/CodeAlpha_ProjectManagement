# Copy this file to .env and adjust values as needed.

# PostgreSQL connection URL (transaction pooler connection for Prisma client)
DATABASE_URL="postgres://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbounce=true"

# Direct connection URL (session connection, used for running migrations)
DIRECT_URL="postgres://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:5432/postgres"

# Secret used to sign JWT access tokens. Use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-secret"

# Port the HTTP + WebSocket server listens on
PORT=3000
